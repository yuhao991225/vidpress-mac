{
  "name": "vidpress-mac",
  "version": "0.3.4",
  "description": "A native SwiftUI macOS app for local video compression with FFmpeg.",
  "license": "MIT",
  "author": "",
  "scripts": {
    "bootstrap:cn": "FFMPEG_BINARIES_URL=https://npmmirror.com/mirrors/ffmpeg-static npm install",
    "dev": "swift run VidPressNative",
    "build": "swift build -c release",
    "dist": "scripts/build-native-mac.sh",
    "smoke": "scripts/smoke-native-core.sh"
  },
  "keywords": [
    "video",
    "compression",
    "ffmpeg",
    "swiftui",
    "macos"
  ],
  "dependencies": {
    "@ffprobe-installer/darwin-arm64": "^5.0.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0"
  }
}
